<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ตัวช่วยสร้างระบบ Merge เอกสาร</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root{--blue:#1a73e8;--blue-d:#1558b0;--blue-l:#e8f0fe;--ink:#202124;--muted:#5f6368;--line:#dadce0;
    --bg:#f6f8fc;--ok:#188038;--ok-bg:#e6f4ea;--err:#d93025;--err-bg:#fce8e6;--warn:#b06000;--warn-bg:#fef7e0;--radius:14px;}
  *{box-sizing:border-box;} html,body{margin:0;}
  body{font-family:'Sarabun','Tahoma',sans-serif;color:var(--ink);background:var(--bg);font-size:15px;line-height:1.55;}
  .topbar{background:linear-gradient(135deg,var(--blue),#4285f4);color:#fff;padding:18px;display:flex;gap:13px;align-items:center;box-shadow:0 3px 12px rgba(26,115,232,.28);}
  .topbar .logo{width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-size:24px;flex:0 0 auto;}
  .topbar h1{font-size:19px;margin:0;font-weight:700;} .topbar p{font-size:13px;margin:2px 0 0;opacity:.92;}
  .wrap{max-width:820px;margin:0 auto;padding:18px 16px 70px;}
  .card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:18px 20px;margin-bottom:16px;}
  .step{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
  .step .n{width:28px;height:28px;border-radius:50%;background:var(--blue);color:#fff;font-weight:700;display:flex;align-items:center;justify-content:center;font-size:15px;flex:0 0 auto;}
  .step h2{font-size:16px;margin:0;font-weight:700;}
  .drops{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  @media(max-width:560px){.drops{grid-template-columns:1fr;}}
  .drop{border:2px dashed var(--line);border-radius:12px;padding:20px 16px;text-align:center;cursor:pointer;transition:.15s;background:#fafbff;}
  .drop:hover{border-color:var(--blue);background:var(--blue-l);}
  .drop.has{border-style:solid;border-color:var(--ok);background:#f3fbf5;}
  .drop .ic{font-size:30px;} .drop .t{font-weight:700;margin-top:6px;font-size:14.5px;} .drop .s{font-size:12.5px;color:var(--muted);margin-top:2px;word-break:break-all;}
  .mode{display:flex;gap:10px;margin:16px 0 4px;flex-wrap:wrap;}
  .mode .opt{flex:1;min-width:180px;border:1.5px solid var(--line);border-radius:11px;padding:12px 14px;cursor:pointer;font-size:14px;}
  .mode .opt.sel{border-color:var(--blue);background:var(--blue-l);}
  .mode .opt b{display:block;font-size:14.5px;} .mode .opt small{color:var(--muted);}
  .btn{font-family:inherit;font-weight:700;border-radius:11px;cursor:pointer;padding:13px 20px;border:1px solid transparent;font-size:15px;display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:.15s;}
  .btn-primary{color:#fff;background:var(--blue);box-shadow:0 3px 10px rgba(26,115,232,.35);}
  .btn-primary:hover{background:var(--blue-d);transform:translateY(-1px);}
  .btn-primary:disabled{background:#9aa0a6;box-shadow:none;transform:none;cursor:default;}
  .btn-block{width:100%;} .mt{margin-top:14px;}
  .alertbox{border-radius:11px;padding:11px 14px;font-size:13.5px;margin-bottom:12px;}
  .a-ok{background:var(--ok-bg);color:#137333;} .a-warn{background:var(--warn-bg);color:var(--warn);} .a-err{background:var(--err-bg);color:#a50e0e;}
  .flist{list-style:none;padding:0;margin:8px 0 0;}
  .flist li{padding:7px 2px;border-bottom:1px solid #eef0f2;font-size:14px;display:flex;gap:8px;align-items:flex-start;}
  .tag{display:inline-block;border-radius:20px;padding:1px 9px;font-size:12px;font-weight:600;}
  .tag.ok{background:var(--ok-bg);color:#137333;} .tag.no{background:var(--err-bg);color:#a50e0e;} .tag.info{background:#e8f0fe;color:var(--blue-d);}
  .spin{width:16px;height:16px;border:2.5px solid rgba(255,255,255,.45);border-top-color:#fff;border-radius:50%;animation:sp .7s linear infinite;display:inline-block;}
  @keyframes sp{to{transform:rotate(360deg);}}
  .hidden{display:none;}
  code{background:#f1f3f4;border-radius:5px;padding:1px 6px;font-size:13px;}
  .steps{counter-reset:s;padding-left:0;list-style:none;margin:6px 0 0;}
  .steps li{position:relative;padding:6px 0 6px 30px;font-size:14px;}
  .steps li:before{counter-increment:s;content:counter(s);position:absolute;left:0;top:6px;width:20px;height:20px;border-radius:50%;background:var(--blue-l);color:var(--blue-d);font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;}
  .muted{color:var(--muted);font-size:13px;}
</style>
</head>
<body>
  <div class="topbar">
    <div class="logo">🛠️</div>
    <div><h1>ตัวช่วยสร้างระบบ Merge เอกสาร</h1><p>อัปโหลด Excel + Word → ตรวจไฟล์ → รับชุดโค้ด + ไฟล์ที่จัดระเบียบแล้ว พร้อมคู่มือ</p></div>
  </div>

  <div class="wrap">
    <!-- STEP 1 -->
    <div class="card">
      <div class="step"><div class="n">1</div><h2>อัปโหลดไฟล์</h2></div>
      <div class="drops">
        <label class="drop" id="dropX">
          <div class="ic">📊</div><div class="t">ไฟล์ Excel (.xlsx)</div>
          <div class="s" id="nameX">ตารางข้อมูล — แถวแรกเป็นหัวคอลัมน์</div>
          <input type="file" accept=".xlsx,.xls" id="fileX" class="hidden">
        </label>
        <label class="drop" id="dropW">
          <div class="ic">📝</div><div class="t">ไฟล์ Word (.docx)</div>
          <div class="s" id="nameW">เทมเพลต — วางฟิลด์ {{ชื่อฟิลด์}} หรือ MERGEFIELD</div>
          <input type="file" accept=".docx" id="fileW" class="hidden">
        </label>
      </div>

      <div class="mode" id="modeBox">
        <div class="opt sel" data-mode="sheet" onclick="setMode('sheet')"><b>◉ แบบใช้ในชีต</b><small>ใช้เมนู/แผงปุ่มในสเปรดชีต</small></div>
        <div class="opt" data-mode="webapp" onclick="setMode('webapp')"><b>○ แบบ Web App</b><small>ได้หน้าเว็บ + ลิงก์ไปใช้งาน</small></div>
      </div>

      <button class="btn btn-primary btn-block mt" id="checkBtn" disabled onclick="checkFiles()">
        <span id="checkLabel">🔍 ตรวจไฟล์เอกสาร</span>
      </button>
    </div>

    <!-- STEP 2 -->
    <div class="card hidden" id="reportCard">
      <div class="step"><div class="n">2</div><h2>ผลการตรวจ</h2></div>
      <div id="report"></div>
      <button class="btn btn-primary btn-block mt" id="genBtn" onclick="generate()">
        <span id="genLabel">⚙️ สร้างระบบ + ดาวน์โหลด .zip</span>
      </button>
    </div>

    <!-- STEP 3 -->
    <div class="card hidden" id="doneCard">
      <div class="step"><div class="n">3</div><h2>ติดตั้งและใช้งาน</h2></div>
      <div id="instructions"></div>
    </div>
  </div>

<script>
/* ===== ไฟล์โค้ดที่ฝังไว้ (base64) ===== */
var B64_CODE   = "";
var B64_INDEX  = "";
var B64_DIALOG = "";
function b64toStr(b64){var bin=atob(b64);var by=new Uint8Array(bin.length);for(var i=0;i<bin.length;i++)by[i]=bin.charCodeAt(i);return new TextDecoder('utf-8').decode(by);}

/* ===== เครื่องยนต์วิเคราะห์ (เหมือนที่ระบบจริงใช้) ===== */
var PART_RE=/^word\/(document|header\d*|footer\d*)\.xml$/;
function getRpr(run){var m=run.match(/<w:rPr\b[^>]*\/>|<w:rPr\b[^>]*>[\s\S]*?<\/w:rPr>/);return m?m[0]:'';}
function rebuildMergeRuns(pxml){
  var runRe=/<w:r\b[^>]*>[\s\S]*?<\/w:r>/g;var arr=[],pos=[],m;
  while((m=runRe.exec(pxml))!==null){arr.push(m[0]);pos.push([m.index,runRe.lastIndex]);}
  function simple(r){if(r.indexOf('fldChar')!==-1||r.indexOf('instrText')!==-1||r.indexOf('<w:br')!==-1||r.indexOf('<w:tab')!==-1)return null;var t=r.match(/<w:t\b[^>]*>([\s\S]*?)<\/w:t>/);return t?t[1]:null;}
  var out=[],last=0,i=0;
  while(i<arr.length){var txt=simple(arr[i]);if(txt===null){i++;continue;}var rpr=getRpr(arr[i]),text=txt,j=i+1;while(j<arr.length&&getRpr(arr[j])===rpr&&simple(arr[j])!==null){text+=simple(arr[j]);j++;}if(j>i+1){out.push(pxml.substring(last,pos[i][0]));out.push('<w:r>'+rpr+'<w:t xml:space="preserve">'+text+'</w:t></w:r>');last=pos[j-1][1];}i=j;}
  out.push(pxml.substring(last));return out.join('');
}
function extractFields(parts){
  var set={};
  parts.forEach(function(xml){
    var instr='',mm,re=/<w:instrText[^>]*>([\s\S]*?)<\/w:instrText>/g;
    while((mm=re.exec(xml))!==null)instr+=mm[1];
    instr.split(/MERGEFIELD/).forEach(function(seg,idx){if(idx===0)return;var name=seg.replace(/^\s+/,'');var cut=name.search(/[\\\r\n]|\s\s|<|\/\//);if(cut>0)name=name.substring(0,cut);name=name.trim().replace(/^"([\s\S]*?)"$/,'$1').trim();if(name)set[name]=true;});
    var plain=xml.replace(/<[^>]+>/g,'');var pm,pre=/\{\{\s*([^}]+?)\s*\}\}/g;while((pm=pre.exec(plain))!==null)set[pm[1].trim()]=true;
  });
  return Object.keys(set);
}

/* ===== สถานะ ===== */
var fileX=null, fileW=null, mode='sheet', analysis=null;

document.getElementById('fileX').addEventListener('change',function(e){onFile('X',e.target.files[0]);});
document.getElementById('fileW').addEventListener('change',function(e){onFile('W',e.target.files[0]);});
function onFile(which,f){
  if(!f)return;
  if(which==='X'){fileX=f;document.getElementById('nameX').textContent=f.name;document.getElementById('dropX').classList.add('has');}
  else{fileW=f;document.getElementById('nameW').textContent=f.name;document.getElementById('dropW').classList.add('has');}
  document.getElementById('checkBtn').disabled=!(fileX&&fileW);
}
function setMode(m){mode=m;document.querySelectorAll('.mode .opt').forEach(function(o){var s=o.dataset.mode===m;o.classList.toggle('sel',s);o.querySelector('b').textContent=(s?'◉ ':'○ ')+(o.dataset.mode==='sheet'?'แบบใช้ในชีต':'แบบ Web App');});}

var norm=function(s){return String(s).replace(/[\s\u200b]/g,'').toLowerCase();};
function lev(a,b){a=norm(a);b=norm(b);var m=a.length,n=b.length,d=[];for(var i=0;i<=m;i++)d[i]=[i];for(var j=0;j<=n;j++)d[0][j]=j;for(i=1;i<=m;i++)for(j=1;j<=n;j++)d[i][j]=Math.min(d[i-1][j]+1,d[i][j-1]+1,d[i-1][j-1]+(a[i-1]===b[j-1]?0:1));return d[m][n];}

async function checkFiles(){
  var btn=document.getElementById('checkBtn');btn.disabled=true;
  document.getElementById('checkLabel').innerHTML='<span class="spin"></span> กำลังตรวจ…';
  try{
    // อ่าน Word
    var wbuf=await fileW.arrayBuffer();
    var zip=await JSZip.loadAsync(wbuf);
    var parts=[],names=[];zip.forEach(function(p){if(PART_RE.test(p))names.push(p);});
    for(var i=0;i<names.length;i++)parts.push(await zip.file(names[i]).async('string'));
    var fields=extractFields(parts);

    // อ่าน Excel (หัวคอลัมน์ + ข้อมูล)
    var xbuf=await fileX.arrayBuffer();
    var wb=XLSX.read(new Uint8Array(xbuf),{type:'array'});
    var sheetName=wb.SheetNames.indexOf('ข้อมูล')>=0?'ข้อมูล':wb.SheetNames[0];
    var aoa=XLSX.utils.sheet_to_json(wb.Sheets[sheetName],{header:1,defval:''});
    var headers=(aoa[0]||[]).map(function(h){return String(h).trim();}).filter(Boolean);
    var dataRows=aoa.slice(1).filter(function(r){return r.some(function(c){return String(c).trim()!=='';});});

    // จับคู่
    var hExact={};headers.forEach(function(h){hExact[h]=1;});
    var hByNorm={};headers.forEach(function(h){hByNorm[norm(h)]=h;});
    var matched=[],aliasFix=[],addCols=[];
    fields.forEach(function(f){
      if(hExact[f]){matched.push({field:f,col:f});return;}                         // ตรงเป๊ะ
      if(hByNorm[norm(f)]!==undefined){aliasFix.push({field:f,col:hByNorm[norm(f)]});return;} // ต่างแค่ช่องว่าง/ตัวพิมพ์ -> ใส่นามแฝง
      var best=null,bd=99;headers.forEach(function(h){var d=lev(f,h);if(d<bd){bd=d;best=h;}});
      if(best&&bd<=2){aliasFix.push({field:f,col:best});}                          // ใกล้เคียง -> ใส่นามแฝง
      else{addCols.push(f);}                                                        // ไม่มีคอลัมน์รองรับ -> เพิ่มคอลัมน์
    });
    var usedNorms={};matched.concat(aliasFix).forEach(function(x){usedNorms[norm(x.col)]=1;});
    var unused=headers.filter(function(h){return !usedNorms[norm(h)];});

    var tmplName=fileW.name.replace(/\.docx$/i,'').trim()||'แม่แบบ1';
    analysis={fields:fields,headers:headers,dataRows:dataRows,matched:matched,aliasFix:aliasFix,addCols:addCols,unused:unused,
      templateName:tmplName,docxName:fileW.name,parts:names};
    renderReport();
    document.getElementById('reportCard').classList.remove('hidden');
    document.getElementById('reportCard').scrollIntoView({behavior:'smooth'});
  }catch(e){
    document.getElementById('reportCard').classList.remove('hidden');
    document.getElementById('report').innerHTML='<div class="alertbox a-err">❌ อ่านไฟล์ไม่สำเร็จ: '+(e.message||e)+'<br>ตรวจว่าไฟล์เป็น .xlsx และ .docx จริง</div>';
    document.getElementById('genBtn').classList.add('hidden');
  }
  document.getElementById('checkLabel').textContent='🔍 ตรวจไฟล์เอกสาร';btn.disabled=false;
}

function renderReport(){
  var a=analysis,h='';
  var pass = a.addCols.length===0;
  h+='<div class="alertbox '+(pass?'a-ok':'a-warn')+'">'+
     (pass?'✅ ไฟล์ตรงกัน พร้อมสร้างระบบ':'⚠️ พบฟิลด์บางตัวไม่มีคอลัมน์รองรับ — ระบบจะเพิ่มคอลัมน์ให้อัตโนมัติ')+
     '<br><span class="muted" style="color:inherit">ฟิลด์ในเอกสาร '+a.fields.length+' ตัว · หัวคอลัมน์ '+a.headers.length+' คอลัมน์'+
     (a.parts.length>1?(' · ตรวจหัว/ท้ายกระดาษด้วย ('+a.parts.length+' ส่วน)'):'')+'</span></div>';
  h+='<ul class="flist">';
  a.matched.forEach(function(x){h+='<li><span class="tag ok">ตรง</span> <b>{{'+esc(x.field)+'}}</b> ↔ คอลัมน์ “'+esc(x.col)+'”</li>';});
  a.aliasFix.forEach(function(x){h+='<li><span class="tag info">แก้ให้</span> <b>{{'+esc(x.field)+'}}</b> ≈ คอลัมน์ “'+esc(x.col)+'” — จะเพิ่มนามแฝงให้อัตโนมัติ</li>';});
  a.addCols.forEach(function(f){h+='<li><span class="tag no">เพิ่มคอลัมน์</span> <b>{{'+esc(f)+'}}</b> ไม่มีคอลัมน์ — จะเพิ่มคอลัมน์ “'+esc(f)+'” ให้ในไฟล์ Excel</li>';});
  a.unused.forEach(function(c){h+='<li><span class="tag info">ไม่ได้ใช้</span> คอลัมน์ “'+esc(c)+'” ไม่มีฟิลด์ในเอกสาร (ใช้เก็บข้อมูลได้ตามปกติ)</li>';});
  h+='</ul>';
  if(!a.fields.length)h='<div class="alertbox a-err">❌ ไม่พบฟิลด์ในไฟล์ Word — วางฟิลด์เป็น <code>{{ชื่อฟิลด์}}</code> หรือ MERGEFIELD ก่อน</div>';
  document.getElementById('report').innerHTML=h;
  document.getElementById('genBtn').classList.toggle('hidden', a.fields.length===0);
}
function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

async function generate(){
  var btn=document.getElementById('genBtn');btn.disabled=true;
  document.getElementById('genLabel').innerHTML='<span class="spin"></span> กำลังสร้าง…';
  try{
    var a=analysis;
    var zip=new JSZip();

    // 1) โค้ด
    zip.file('Code.gs', b64toStr(B64_CODE));
    zip.file('MergeDialog.html', b64toStr(B64_DIALOG));
    zip.file('Index.html', b64toStr(B64_INDEX));

    // 2) Excel ที่จัดระเบียบแล้ว  (ใช้ชื่อไฟล์อังกฤษล้วน กัน Windows แตกไฟล์แล้วชื่อเพี้ยน/เปิดไม่ได้)
    var xbuf=buildWorkbook(a);
    zip.file('system.xlsx', xbuf);

    // 3) Word ที่ปรับ run ให้ {{ }} ต่อกัน (รูปแบบเดิม)
    var normDocx=await normalizeDocx(await fileW.arrayBuffer());
    zip.file('template.docx', normDocx);

    // 4) คู่มือ
    zip.file('README.md', buildReadme(a));

    var blob=await zip.generateAsync({type:'blob',compression:'DEFLATE',compressionOptions:{level:6}});
    downloadBlob(blob, 'merge-system.zip');
    renderInstructions(a);
    document.getElementById('doneCard').classList.remove('hidden');
    document.getElementById('doneCard').scrollIntoView({behavior:'smooth'});
  }catch(e){
    alert('สร้างไม่สำเร็จ: '+(e.message||e));
  }
  document.getElementById('genLabel').textContent='⚙️ สร้างระบบ + ดาวน์โหลด .zip';btn.disabled=false;
}

function buildWorkbook(a){
  var wb=XLSX.utils.book_new();
  // ข้อมูล
  var newHeaders=['แม่แบบ'].concat(a.headers).concat(a.addCols);
  var rows=[newHeaders];
  (a.dataRows.length?a.dataRows:[[]]).forEach(function(r){
    var row=[a.templateName];
    a.headers.forEach(function(h,i){row.push(r[i]!=null?r[i]:'');});
    a.addCols.forEach(function(){row.push('');});
    rows.push(row);
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), 'ข้อมูล');
  // แม่แบบ
  var firstField=(a.matched[0]&&a.matched[0].col)||a.headers[0]||'';
  var pattern=firstField?('{{'+firstField+'}}'):'';
  var tpl=[['ชื่อแม่แบบ','Drive File ID (.docx)','รูปแบบชื่อไฟล์ (ใส่ {{ฟิลด์}} ได้)'],
           [a.templateName,'<< วาง File ID ของ template.docx >>',pattern]];
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(tpl), 'แม่แบบ');
  // ตั้งค่า
  var cfg=[['Output Folder ID (โฟลเดอร์ Google Drive ที่เก็บผลลัพธ์)','<< วาง Folder ID ที่นี่ >>'],
           ['คอลัมน์ที่ใช้แสดงชื่อ/ตั้งชื่อโฟลเดอร์ย่อย (เว้นว่างได้)',firstField],
           ['แยกโฟลเดอร์ย่อยตามคอลัมน์ข้างบน (ใช่/ไม่)','ไม่'],
           ['',''],
           ['จำนวนวันที่ต้องดำเนินการให้แล้วเสร็จ (SLA)',15]];
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(cfg), 'ตั้งค่า');
  // นามแฝงฟิลด์
  var al=[['ชื่อฟิลด์ในเทมเพลต','หัวคอลัมน์จริงในชีท "ข้อมูล"']];
  a.aliasFix.forEach(function(x){al.push([x.field,x.col]);});
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(al), 'นามแฝงฟิลด์');
  // อ่านก่อน
  var g=[['ระบบ Merge เอกสาร → Word (.docx) รูปแบบไม่เพี้ยน'],[''],
         ['1) ใส่ Output Folder ID ในชีท "ตั้งค่า"'],
         ['2) อัปโหลด template.docx ขึ้น Drive แล้ววาง File ID ในชีท "แม่แบบ"'],
         ['3) เมนู 📨 แพลตฟอร์มเอกสาร > ➕ เพิ่มคอลัมน์ Checkbox แล้วเริ่มสร้างเอกสาร'],
         ['* ดูรายละเอียดใน README.md']];
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(g), 'อ่านก่อน');
  var out=XLSX.write(wb,{type:'array',bookType:'xlsx'});
  return out;
}

async function normalizeDocx(buf){
  var zip=await JSZip.loadAsync(buf);
  var names=[];zip.forEach(function(p){if(PART_RE.test(p))names.push(p);});
  for(var i=0;i<names.length;i++){
    var xml=await zip.file(names[i]).async('string');
    xml=xml.replace(/<w:p\b[^>]*>[\s\S]*?<\/w:p>/g,function(p){return rebuildMergeRuns(p);});
    zip.file(names[i],xml);
  }
  return await zip.generateAsync({type:'uint8array',compression:'DEFLATE',compressionOptions:{level:6},
    mimeType:'application/vnd.openxmlformats-officedocument.wordprocessingml.document'});
}

